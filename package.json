{
  "name": "swipi-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic framework for end-to-end web-game creation from a prompt — Claude-powered, REST-exposable, and installable as a Claude Code plugin.",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "plugin:build": "npm run build --workspace=@swipi/plugin-claude-code",
    "plugin:verify": "node packages/plugin-claude-code/scripts/verify-plugin.mjs",
    "smoke": "node packages/core/scripts/smoke-test.mjs && node packages/api/scripts/smoke-test.mjs"
  }
}

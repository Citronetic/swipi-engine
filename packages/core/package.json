{
  "name": "@swipi/core",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-agnostic game-generation engine: classify-game, generate-gdd, generate-assets, generate-tilemap, plus Template Skill and Debug Skill evolution pipelines. Provider-agnostic via the LLMClient adapter.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./skills/template": {
      "types": "./dist/skills/template-skill/index.d.ts",
      "import": "./dist/skills/template-skill/index.js"
    },
    "./skills/debug": {
      "types": "./dist/skills/debug-skill/index.d.ts",
      "import": "./dist/skills/debug-skill/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.14.0"
  }
}
